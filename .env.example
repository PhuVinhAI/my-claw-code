# File cấu hình môi trường cho Claw Code
# Copy file này thành .env và điền thông tin của bạn

# Anthropic API Key (mặc định)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxx

# Model mặc định
CLAW_MODEL=sonnet

# [TÙY CHỌN] Dùng OpenAI thay vì Anthropic
# OPENAI_API_KEY=sk-xxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# CLAW_MODEL=gpt-4o

# [TÙY CHỌN] Dùng NVIDIA API
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_API_KEY=nvapi-xxxxxx
# CLAW_MODEL=stepfun-ai/step-3.5-flash

# [TÙY CHỌN] Dùng Local LLM (LM Studio, Ollama, etc.)
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# CLAW_MODEL=your-local-model
